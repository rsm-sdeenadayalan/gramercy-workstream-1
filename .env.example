# ─────────────────────────────────────────────────────────────────────────────
# Gramercy Sub-Index Pipelines — environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (one server hosts subindex_1, subindex_2, subindex_4) ──────────
# The pipelines connect via SSH tunnel — see README "Open SSH tunnel" step.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=
POSTGRES_PASSWORD=

# Optional per-pipeline overrides if your DB user differs across sub-index DBs.
# If unset, the pipelines fall back to POSTGRES_USER / POSTGRES_PASSWORD above.
# SI4_POSTGRES_USER=
# SI4_POSTGRES_PASSWORD=

# ── SSH tunnel (informational — actual SSH is a manual step) ──────────────────
SSH_HOST=rsm-compute-02.ucsd.edu
SSH_USER=

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required for: research-agent synthesis (SI1, SI2, SI4) + SI2 regulatory NLP
ANTHROPIC_API_KEY=

# ── Search backends for the research agent (at least one required) ────────────
# Tavily is preferred (1 000 free searches / month). Brave + Jina are fallbacks.
TAVILY_API_KEY=
BRAVE_API_KEY=
JINA_API_KEY=

# ── Direct-API collectors (SI1) ───────────────────────────────────────────────
EIA_API_KEY=
DATAGOV_SG_API_KEY=

# ── Optional / legacy ─────────────────────────────────────────────────────────
# Gemini was used by an earlier collector path; current pipelines use Claude.
# GEMINI_API_KEY=
