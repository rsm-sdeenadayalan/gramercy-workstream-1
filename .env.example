# ─────────────────────────────────────────────────────────────────────────────
# Gramercy Sub-Index Pipelines — environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Single database hosts all sub-index tables (si1_*, si2_*, si3_*, si4_*, score_*).
# Default port 5432; some setups use 5433 (SSH tunnel) or 5440 (Postgres.app side-install).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=gramercy_workstream1

# Optional per-pipeline overrides (rarely needed).
# SI3_POSTGRES_USER=
# SI3_POSTGRES_PASSWORD=
# SI4_POSTGRES_USER=
# SI4_POSTGRES_PASSWORD=

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required. Used by:
#   • research_agent.py (deep research for any metric the cheap collectors miss)
#   • si1_pipeline.py — note: helpers named `gemini_*` actually call Claude
#     (vestigial names from a partial rename; no Gemini call exists)
#   • si2_collectors.py — regulatory-text classification
ANTHROPIC_API_KEY=
# Optional model override; default is claude-haiku-4-5-20251001
# CLAUDE_RESEARCH_MODEL=claude-haiku-4-5-20251001

# ── Tavily (sole search backend for the research agent) ──────────────────────
# Free tier: 1000 searches/month. Sign up at https://tavily.com.
TAVILY_API_KEY=

# ── Direct-API collectors ────────────────────────────────────────────────────
# SI1 (Energy):
EIA_API_KEY=                # https://www.eia.gov/opendata/register.php (free, instant)
DATAGOV_SG_API_KEY=         # https://data.gov.sg (Singapore-specific tariff data)

# SI3 (Minerals) — UN Comtrade subscription key:
# Free tier: 10K calls/day, replenishes daily. Sign up at:
#   https://comtradeplus.un.org → Register → Subscriptions → "Free API – Subscribed"
# If empty, SI3 will use the anonymous preview endpoint (500-record cap; world
# denominator may be truncated). Setting SI3_SKIP_COMTRADE=1 below skips
# Comtrade entirely and routes through the research agent.
COMTRADE_KEY=

# ── Pipeline tuning knobs (defaults are fine for most users) ─────────────────
# SI3 Comtrade per-call pacing delay (seconds). Default 1.0. Comtrade's free
# tier is 10K calls/day with no published per-minute cap; 1s pacing keeps a
# full SI3 run (~520 calls) at ~9 minutes total and stays well within both
# daily and per-minute budgets. The pipeline ALSO trips a circuit breaker
# the first time a 403-quota response is seen — every subsequent
# _comtrade_get returns empty without an API call, preventing the 4×
# burn-through from per-cell retries.
# SI3_COMTRADE_DELAY_S=1.0
#
# SI3 Comtrade hard timeout per API call (seconds). Default 120.
# SI3_COMTRADE_TIMEOUT=120
#
# SI3 quota-replenishment sleep cap (seconds). Comtrade's 403 includes a
# replenishment ETA — anything above this cap is treated as "skip and let
# the cascade fall back" rather than blocking the pipeline for hours. Default 600.
# SI3_COMTRADE_QUOTA_WAIT_MAX=600
#
# SI3 escape hatch — set to 1 to bypass Comtrade entirely (research agent
# fills refining_share and value_add_ratio). Use when quota is depleted.
# SI3_SKIP_COMTRADE=0
#
# run_all.py per-pipeline idle-timeout watchdog (seconds). A subprocess with
# no stdout activity for longer than this is killed via SIGTERM/SIGKILL on its
# process group. Default 600 (10 min).
# WS1_PIPELINE_IDLE_TIMEOUT=600
