# ─────────────────────────────────────────────────────────────────────────────
# Gramercy Sub-Index Pipelines — environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (one server hosts subindex_1..subindex_4) ──────────────────────
# Set HOST/PORT to wherever your Postgres lives. Use localhost:5433 if you're
# tunneling through an SSH bastion (see README §3).
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=
POSTGRES_PASSWORD=

# Optional per-pipeline overrides if your DB user differs across sub-index DBs.
# If unset, the pipelines fall back to POSTGRES_USER / POSTGRES_PASSWORD above.
# SI4_POSTGRES_USER=
# SI4_POSTGRES_PASSWORD=

# ── SSH tunnel (only if your DB is behind a bastion — purely informational) ───
# SSH_HOST=
# SSH_USER=

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required for: research-agent synthesis (SI1, SI2, SI4) + SI2 regulatory NLP
ANTHROPIC_API_KEY=
# Optional: override the model used by research_agent.py (default: claude-haiku-4-5-20251001)
# CLAUDE_RESEARCH_MODEL=claude-haiku-4-5-20251001

# ── Search backend for the research agent ────────────────────────────────────
# Tavily is the sole search backend (1 000 free searches / month).
TAVILY_API_KEY=

# ── Direct-API collectors (SI1) ───────────────────────────────────────────────
EIA_API_KEY=
DATAGOV_SG_API_KEY=

# ── Optional / legacy ─────────────────────────────────────────────────────────
# Gemini was used by an earlier collector path; current pipelines use Claude.
# GEMINI_API_KEY=
